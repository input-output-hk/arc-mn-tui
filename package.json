{
  "name": "mn-tui",
  "version": "0.1.0",
  "description": "Terminal UI for basic Midnight wallet operations",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.tsx",
    "dev":   "tsx watch src/index.tsx",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink":            "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner":    "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react":          "^18.3.1"
  },
  "devDependencies": {
    "@types/node":    "^22.0.0",
    "@types/react":   "^18.3.1",
    "tsx":            "^4.19.0",
    "typescript":     "^5.7.0"
  }
}
